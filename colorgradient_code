% Create sample surface
[x,y] = meshgrid(-2:0.05:2);
z = x.^2 - y.^2;

% Map colors to z (or any C you choose)
C = z;         % colors vary with z
surf(x,y,z,C)
shading interp
colorbar
xlabel('x'), ylabel('y'), zlabel('z')

% Create a colormap that goes from green to red (N colors)
N = 256;
cmap = [linspace(0,1,N)' , linspace(1,0,N)' , zeros(N,1)]; % [R G B]
colormap(cmap)

% Optional: fix color limits
caxis([min(C(:)) max(C(:))])
